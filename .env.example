# AI provider (required) — OpenRouter API key for Claude 3.5 Haiku calls
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Supabase connection string — Supabase dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Server configuration
PORT=3000
NODE_ENV=development

# Admin dashboard — secret key for accessing /api/admin/* endpoints
# Generate with: openssl rand -hex 32
ADMIN_KEY=your-admin-secret-key-here

# Admin dashboard 2FA — base32 TOTP secret. Required alongside ADMIN_KEY.
# Generate with: tsx scripts/gen-admin-totp.ts  (prints QR + secret)
# Scan the QR with 1Password (or any TOTP app), then paste the secret here.
ADMIN_TOTP_SECRET=your-base32-totp-secret-here

# Admin session-token signing secret (v1.14.5). Used to sign JWTs issued
# after successful key+TOTP login. Rotating this acts as "log out all
# sessions" — any token signed with a previous secret immediately fails.
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your-jwt-signing-secret-here

# Optional: AI model override (env fallback in the v1.9.0 resolver chain).
# Resolution priority (highest → lowest):
#   1. X-Test-Model HTTP header (dev only — NODE_ENV !== 'production')
#   2. Admin runtime override stored in app_config (flipped from /admin)
#   3. AI_MODEL_OVERRIDE env var (this)
#   4. DEFAULT_MODEL hardcoded in server/aiModel.ts (Haiku)
# In practice the admin DB toggle is the main lever now; this env var is the
# sysadmin escape hatch when the admin UI is unavailable.
# Example: AI_MODEL_OVERRIDE=anthropic/claude-sonnet-4
AI_MODEL_OVERRIDE=

# Optional: error tracking (leave empty for local development)
SENTRY_DSN=

# Optional: client-side analytics (set both for prod; leave empty locally)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Issue-report email forwarding (v1.13.0). When all three are set, new bug
# reports posted via the in-app IssueReportSheet get forwarded by email so
# the team is notified without polling /admin. When missing, reports still
# save to the DB and surface in /admin — the email step just no-ops.
#
# Setup:
#   1. Sign up at resend.com (free tier: 3000 emails/month, 100/day)
#   2. Verify mystorymode.com in the Resend dashboard (SPF + DKIM TXT
#      records on GoDaddy DNS). Required: `onboarding@resend.dev` only
#      allows sending TO your account's signup address.
#   3. Set ISSUE_REPORT_FROM_EMAIL to an address on the verified domain
#      (e.g. noreply@mystorymode.com)
#   4. Set ISSUE_REPORT_TO_EMAIL to wherever you want to receive reports
RESEND_API_KEY=
ISSUE_REPORT_FROM_EMAIL=noreply@mystorymode.com
ISSUE_REPORT_TO_EMAIL=feedback@mystorymode.com
